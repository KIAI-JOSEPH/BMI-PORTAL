# BMI University Management System - Environment Configuration
# Copy this file to .env and update the values

# Server Configuration
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# Security - CHANGE THESE IN PRODUCTION!
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-long
JWT_EXPIRES_IN=24h
ENCRYPTION_KEY=your-32-char-encryption-key!!

# PocketBase Configuration
POCKETBASE_URL=http://127.0.0.1:8090
POCKETBASE_ADMIN_EMAIL=admin@bmi.edu
POCKETBASE_ADMIN_PASSWORD=change-this-secure-password

# Ollama (Local LLM) Configuration
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2

# CORS (set to your frontend URL in production)
CORS_ORIGIN=http://localhost:3000

# Logging
LOG_LEVEL=info

# Note: This system uses 100% open-source components:
# - Ollama (MIT) for local AI
# - PocketBase (MIT) for database and auth
# - Hono (MIT) for API server
# - All data stays on YOUR server - zero external API calls
