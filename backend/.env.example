# BMI University Management System - Environment Configuration Template
# Copy this file to .env and fill in real values
# Generate secrets with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"

# Server Configuration
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# Security — MUST be changed before running
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=REPLACE_WITH_96_CHAR_HEX_STRING
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Generate: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
ENCRYPTION_KEY=REPLACE_WITH_32_CHAR_HEX_STRING

# PocketBase Configuration
POCKETBASE_URL=http://127.0.0.1:8090
POCKETBASE_ADMIN_EMAIL=admin@yourdomain.edu
POCKETBASE_ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD_MIN_12_CHARS

# Ollama (Local LLM) Configuration
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2

# CORS — set to your exact frontend URL, never use * in production
CORS_ORIGIN=http://localhost:3000

# Logging
LOG_LEVEL=info
