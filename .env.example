# Frontend Environment Variables Example
# Copy this file to .env and fill in your values

# API Configuration
VITE_API_URL=http://localhost:3001
VITE_POCKETBASE_URL=http://localhost:8090

# Feature Flags
VITE_ENABLE_AI=true
VITE_ENABLE_ANALYTICS=false

# Development
VITE_DEBUG=false

# Public verification portal URL (used in QR codes on printed documents).
# Leave empty for dev (uses localhost). Set in production to your real domain.
# VITE_VERIFY_URL=https://verify.bmiuniversity.ac.ke
VITE_VERIFY_URL=
